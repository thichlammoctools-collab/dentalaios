{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "noEmit": true,
    "paths": {
      "@shared/*": ["../../src/shared/*"],
      "@db/*": ["../../src/db/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../src/shared/**/*.ts",
    "../../src/db/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}