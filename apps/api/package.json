{
  "name": "@dentalaios/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "d1:create": "wrangler d1 create dentalaios-db",
    "d1:migrations:local": "wrangler d1 migrations apply dentalaios-db --local",
    "d1:migrations:remote": "wrangler d1 migrations apply dentalaios-db --remote",
    "d1:seed:local": "wrangler d1 execute dentalaios-db --local --file=../../src/db/seeds/0001_roles.sql",
    "d1:seed:remote": "wrangler d1 execute dentalaios-db --remote --file=../../src/db/seeds/0001_roles.sql",
    "r2:create": "wrangler r2 bucket create dentalaios-files",
    "queue:create": "wrangler queues create dentalaios-jobs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/zod-validator": "^0.4.1",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240712.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4",
    "wrangler": "^4.103.0"
  }
}